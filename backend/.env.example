# Copy to .env for local docker run (never commit .env)
# GitHub Actions uses repository Secrets with the same variable names.

SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/carsharex?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=your-db-user
SPRING_DATASOURCE_PASSWORD=your-db-password
